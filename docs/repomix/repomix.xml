    score: typeof e.scoreValue === 'number' ? e.scoreValue : null,
    explanation: e.explanation,
    traceId: e.traceId,
    timestamp: e.timestamp,
    evaluator: e.evaluator,
    label: e.scoreLabel,
    evaluatorType: e.evaluatorType,
    spanId: e.spanId,
    sessionId: e.sessionId,
    agentName: e.agentName,
