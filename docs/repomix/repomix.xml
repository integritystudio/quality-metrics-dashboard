  sub(/[[:space:]]+tokens/, "", s)
  gsub(/,/, "", s)
  return int(s)
}
{
  lines[NR] = $0
}
END {
  i = 1
  while (i <= NR) {
    if (!is_file(lines[i])) {
      print lines[i]
      i++
      continue
    }
    cp = connector_pos(lines[i])
    # Collect consecutive file siblings at same connector position
    n = 0
    while (i <= NR && is_file(lines[i]) && connector_pos(lines[i]) == cp) {
      n++
      sib_line[n] = lines[i]
      sib_tok[n] = get_tokens(lines[i])
      i++
    }
    if (n > max) {
