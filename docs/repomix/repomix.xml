    traceId,
    evaluationName: 'relevance',
    scoreValue,
    timestamp: ts,
    sessionId: 'sess-x',
    evaluatorType: 'llm',
    id: `${traceId}-${scoreValue}`,
  } as EvaluationResult;
}
