    ['admin', 'roles'],
    () => `${API_BASE}/api/admin/roles`,
  );
  const isLoading = usersLoading || rolesLoading;
  const error = usersError ?? rolesError;
  return (
    <PageShell isLoading={isLoading} error={error} skeletonHeight={SKELETON_HEIGHT_MD}>
