      for (j = 1; j <= n; j++) rank[j] = j
      for (j = 1; j <= n; j++) {
        for (k = j+1; k <= n; k++) {
          if (sib_tok[rank[k]] > sib_tok[rank[j]]) {
            tmp = rank[j]; rank[j] = rank[k]; rank[k] = tmp
