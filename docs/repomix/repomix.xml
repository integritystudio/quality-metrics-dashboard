                    key={user.id}
                    user={user}
                    availableRoles={roles ?? []}
                    onMutationStart={onMutationStart}
                    onMutationEnd={onMutationEnd}
                  />
                ))}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </PageShell>
  );
}

